# Copy to .env and fill in values. Do NOT commit .env.

# ── Ollama ─────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
GENERATION_MODEL=qwen3
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024                 # confirm from BGE-M3 model card before backend pgvector migration

# ── Service-to-service auth ────────────────────────────────
# Must match AI_SERVICE_KEY in jobfit-backend. Sent as header: X-AI-Service-Key
AI_SERVICE_KEY=change-me

# ── Timeouts (seconds) ─────────────────────────────────────
REQUEST_TIMEOUT_GENERATE=60
REQUEST_TIMEOUT_EMBED=10

# ── Server ─────────────────────────────────────────────────
PORT=8000
ENV=development
